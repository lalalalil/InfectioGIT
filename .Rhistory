# 1. Chargement des bibliothèques nécessaires
library(tidyverse)
library(janitor)
library(RColorBrewer)
library(ggplot2)
library(dplyr)
# 2. Chargement du fichier (remplace le nom par ton fichier réel)
df_approach <- read.csv("modelling_approaches_summary.csv") %>%
as_tibble()
# Nettoyage rapide : on enlève les "Not specified" ou "Other" pour y voir plus clair
df_clean <- df_approach %>%
filter(!modelling_approach %in% c("Not specified", "Other", "Unknown"))
# --- STATS 1 : Top des approches au niveau GLOBAL ---
stats_global <- df_clean %>%
count(modelling_approach) %>%
mutate(percentage = n / sum(n) * 100) %>%
arrange(desc(n))
print("Top des approches globales :")
print(stats_global)
# Graphique global
plot_global <- ggplot(stats_global, aes(x = reorder(modelling_approach, n), y = n)) +
geom_col(fill = "#5DADE2") +
coord_flip() +
labs(title = "Répartition globale des types de modélisation",
x = "Type d'approche", y = "Nombre de modèles") +
theme_minimal()
# --- STATS 2 : Répartition des approches PAR MALADIE ---
stats_by_disease <- df_clean %>%
group_by(disease_category, modelling_approach) %>%
summarise(count = n(), .groups = "drop")
# Graphique par maladie (barres empilées à 100% pour comparer les proportions)
plot_disease <- ggplot(stats_by_disease, aes(x = disease_category, y = count, fill = modelling_approach)) +
geom_bar(stat = "identity", position = "fill") +
scale_y_continuous(labels = scales::percent) +
coord_flip() +
labs(title = "Proportion des approches de modélisation par maladie",
x = "Maladie", y = "Part du type de modèle (%)",
fill = "Approche") +
theme_bw() +
theme(legend.position = "bottom", legend.text = element_text(size = 8))
# Affichage
print(plot_global)
print(plot_disease)
