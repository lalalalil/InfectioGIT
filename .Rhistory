# 1. Chargement des bibliothèques nécessaires
install.packages("pacman")
pacman::p_load(tidyverse, janitor, RColorBrewer)
library(tidyverse)
library(janitor)
library(RColorBrewer)
# 2. Chargement des données
# On suppose que les fichiers sont dans votre répertoire de travail
stats_extensions <- read_csv("statistiques_modeles_nettoyes.csv")
stats_approaches <- read_csv("modelling_approaches_summary.csv")
# 2. Chargement des données
# On suppose que les fichiers sont dans votre répertoire de travail
stats_extensions <- read_csv("statistiques_modeles_nettoyes.csv")
# 1. Chargement des bibliothèques nécessaires
library(tidyverse)
library(janitor)
library(RColorBrewer)
library(ggplot2)
library(dplyr)
# 2. Chargement du fichier CSV
df <- read_csv("statistiques_modeles_nettoyes.csv") %>%
clean_names()
# --- STATS 1 : Nombre de modèles par catégorie ---
stats_categories <- df %>%
count(category) %>%
arrange(desc(n))
print("Nombre de modèles par catégorie :")
print(stats_categories)
# Graphique du nombre de modèles
plot_models_count <- ggplot(stats_categories, aes(x = reorder(category, n), y = n, fill = category)) +
geom_col() +
coord_flip() +
labs(title = "Répartition des modèles par maladie",
x = "Maladie", y = "Nombre de modèles") +
theme_minimal() +
theme(legend.position = "none")
# --- STATS 2 : Top des extensions utilisées par maladie ---
# On transforme le format "large" en format "long" pour pouvoir analyser les extensions
df_long <- df %>%
pivot_longer(cols = starts_with("x"), # Les colonnes d'extensions commencent souvent par 'x' après clean_names
names_to = "extension",
values_to = "count") %>%
filter(count > 0) %>%
mutate(extension = str_remove(extension, "^x")) # Nettoyage du nom de l'extension
# Calcul des extensions les plus fréquentes par catégorie
top_extensions <- df_long %>%
group_by(category, extension) %>%
summarise(total_files = sum(count), .groups = "drop") %>%
group_by(category) %>%
slice_max(order_by = total_files, n = 5) # Top 5 des extensions par maladie
# Graphique de la répartition des formats
plot_extensions <- ggplot(top_extensions, aes(x = extension, y = total_files, fill = category)) +
geom_col() +
facet_wrap(~category, scales = "free_y") +
coord_flip() +
labs(title = "Top 5 des formats de fichiers par catégorie",
x = "Extension", y = "Nombre total de fichiers") +
theme_bw() +
theme(legend.position = "none")
# Affichage des graphiques
print(plot_models_count)
print(plot_extensions)
