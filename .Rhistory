ggplot(aes(x = reorder(modelling_approach, n), y = n)) +
geom_col(fill = "steelblue") +
coord_flip() +
labs(
title = "Top 10 des approches de modélisation les plus fréquentes",
x = "Approche (Ontologie MAMO)",
